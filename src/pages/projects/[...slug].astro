---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, tagline, url, stack, status, launchedAt } = project.data;
---
<Base title={`${title} — Gabriel Rubens`} description={tagline}>
  <article class="project-detail">
    <header>
      <a href="/projects" class="more">← All projects</a>
      <h1>{title}</h1>
      <p class="lead">{tagline}</p>
      <div class="meta">
        <span class={`badge badge-${status}`}>{status}</span>
        {stack.map((s) => <span class="tag">{s}</span>)}
        {launchedAt && (
          <span class="tag">
            Launched {launchedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
          </span>
        )}
      </div>
      {url && (
        <a class="cta" href={url} target="_blank" rel="noopener">
          Visit {title} →
        </a>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
