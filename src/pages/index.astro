---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import NowStrip from '../components/NowStrip.astro';
import Coda from '../components/Coda.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const latest = posts[0];
const latestPost = latest
  ? {
      title: latest.data.title,
      slug: latest.id,
      date: latest.data.pubDate
        .toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
        .toLowerCase(),
    }
  : null;
---
<Base title="Gabriel Rubens · Builder">
  <div class="hero">
    <h1>Four products, shipped after <em>day job and leisure time</em>.</h1>
    <p class="lede">
      I'm Gabriel. Developer by background, Agilist for over a decade, now
      Product Owner. These are the products I ship on the side, most of them
      solo.
    </p>

    <div class="hero-products">
      {projects.map((p) => (
        <a href={`/projects/${p.id}`}>
          <div class="pmark" style={`background:${p.data.palette.bg}`}>
            {p.data.icon && <img src={p.data.icon} alt="" />}
          </div>
          <div>
            <div class="pname">{p.data.title}</div>
            {p.data.category && <div class="pfoot">{p.data.category}</div>}
          </div>
          <div class="pfoot">· {p.data.status}</div>
        </a>
      ))}
    </div>

    <span class="currently" style="margin-top:1.5rem;">
      <span class="pulse"></span>
      <span>April&nbsp;2026 · <b>shipping HobbyCat public beta</b></span>
    </span>

    <div style="margin-top:1.5rem;">
      <NowStrip projects={projects} />
    </div>
  </div>

  <div class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">// featured work</div>
        <h2>Four products, <em>all live</em>.</h2>
      </div>
      <a href="/projects" class="more">see all →</a>
    </div>
    <div class="projects">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </div>

  <Coda variant="home" latestPost={latestPost} />
</Base>
