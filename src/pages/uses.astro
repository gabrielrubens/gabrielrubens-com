---
import Base from '../layouts/Base.astro';
---
<Base
  title="Uses — Gabriel Rubens"
  description="The tools, hardware, and software I use every day."
>
  <section class="hero">
    <h1>Uses</h1>
    <p class="lead">
      The tools I reach for when shipping things. Inspired by
      <a href="https://uses.tech" target="_blank" rel="noopener">uses.tech</a>.
    </p>
  </section>

  <section class="prose">
    <h2>Stack</h2>
    <ul>
      <li><strong>Backend:</strong> Rails 8 with Hotwire and Solid Queue/Cache.</li>
      <li><strong>Mobile:</strong> Hotwire Native for iOS and Android.</li>
      <li><strong>Database:</strong> PostgreSQL.</li>
      <li><strong>Hosting:</strong> Hostinger VPS with Kamal 2.</li>
      <li><strong>CDN / DNS:</strong> Cloudflare.</li>
    </ul>

    <h2>Editor</h2>
    <ul>
      <li>Claude Code for most of the heavy lifting.</li>
      <li>VS Code for quick edits.</li>
    </ul>

    <h2>This site</h2>
    <ul>
      <li>Built with Astro, deployed on Cloudflare Pages.</li>
    </ul>
  </section>
</Base>
