---
import Base from '../layouts/Base.astro';
---
<Base title="About — Gabriel Rubens">
  <section class="hero">
    <h1>About</h1>
  </section>

  <section class="prose">
    <p>
      I'm Gabriel Rubens, a Brazilian software developer based in Portugal. By day
      I work as an Agile Coach. By night (and weekends) I build small products —
      mostly Rails + Hotwire Native apps — and ship them to a single VPS with
      Kamal 2.
    </p>

    <p>
      This site is where I keep track of what I'm building, what I'm learning,
      and the goals I'm chasing. The plan is to ship many small useful things
      rather than one big ambitious one.
    </p>

    <h2>Get in touch</h2>
    <ul>
      <li><a href="https://github.com/gabrielrubens" target="_blank" rel="noopener">GitHub</a></li>
      <li><a href="https://www.linkedin.com/in/gabrielrubens" target="_blank" rel="noopener">LinkedIn</a></li>
    </ul>
  </section>
</Base>
