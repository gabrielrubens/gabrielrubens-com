---
import Base from '../layouts/Base.astro';

const lastUpdated = new Date('2026-04-23');
---
<Base
  title="Now — Gabriel Rubens"
  description="What I'm working on right now."
>
  <section class="hero">
    <h1>Now</h1>
    <p class="lead">
      Inspired by <a href="https://nownownow.com/about" target="_blank" rel="noopener">Derek Sivers' /now page movement</a>.
      This is what has my attention right now, updated periodically.
    </p>
  </section>

  <section class="prose">
    <h2>Shipping</h2>
    <ul>
      <li>Building out HobbyCat's design kit across remaining screens.</li>
      <li>Preparing Gravity for the Google Play Store.</li>
    </ul>

    <h2>Learning</h2>
    <ul>
      <li>Refining a reusable blueprint for rapid micro-SaaS development.</li>
      <li>Getting comfortable with Android FCM in production.</li>
    </ul>

    <p class="date">Last updated {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
  </section>
</Base>
