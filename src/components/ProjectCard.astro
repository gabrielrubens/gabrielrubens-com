---
import type { CollectionEntry } from 'astro:content';
import StatusPill from './StatusPill.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, tagline, status, url, palette, screenshot, screenshotOrientation } = project.data;
const domain = url ? url.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';
const shotLabel = `${title.toLowerCase()}.app`;

const styleVars = [
  `--card-bg:${palette.bg}`,
  `--card-ink:${palette.ink}`,
  `--card-ink-2:${palette.ink2}`,
  `--card-dot:${palette.dot}`,
  `--card-mark:${palette.mark}`,
  `--card-accent:${palette.accent}`,
].join(';');
---
<a class="project-card" href={`/projects/${project.id}`} style={styleVars}>
  <div
    class:list={['shot', { 'has-image': !!screenshot, [`is-${screenshotOrientation}`]: !!screenshotOrientation }]}
    data-shot-label={shotLabel}
  >
    {screenshot && <img class="card-shot-image" src={screenshot} alt={`${title} screenshot`} loading="lazy" />}
  </div>
  <div class="body">
    <div class="head">
      <h3 class="title">{title}<em>.</em></h3>
      <StatusPill status={status} accent={palette.accent} />
    </div>
    <p class="tagline">{tagline}</p>
    <div class="foot">
      <span>{domain}</span>
      <span class="arr">→</span>
    </div>
  </div>
</a>
