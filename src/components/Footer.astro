---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner">
    <div class="col">
      <h4>Gabriel Rubens</h4>
      <p>Solo builder shipping small, useful products from Portugal.</p>
    </div>
    <div class="col">
      <h4>Site</h4>
      <ul>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/writing">Writing</a></li>
        <li><a href="/impossible-list">Impossible List</a></li>
        <li><a href="/now">Now</a></li>
        <li><a href="/uses">Uses</a></li>
      </ul>
    </div>
    <div class="col">
      <h4>Elsewhere</h4>
      <ul>
        <li><a href="https://github.com/gabrielrubens" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://www.linkedin.com/in/gabrielrubens" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="/podcast">Podcasts</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">© {year} Gabriel Rubens</div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 2.5rem 1.25rem 2rem;
    background: var(--card);
  }
  .footer-inner {
    max-width: var(--max-page);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2rem;
  }
  .col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }
  .col p { color: var(--muted); font-size: 0.95rem; margin: 0; }
  .col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .col a { color: var(--fg); font-size: 0.95rem; }
  .col a:hover { color: var(--accent); }
  .footer-bottom {
    max-width: var(--max-page);
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
  }
  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
